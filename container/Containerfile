# ==========================================
# BUILD STAGE: Compile Go binary
# Build context: repo root (docker build -f container/Containerfile .)
# ==========================================
FROM golang:1.26 AS builder

WORKDIR /build

# Cache dependencies before copying source — layer is reused unless go.mod/go.sum change
COPY rag-go/go.mod rag-go/go.sum ./
RUN go mod download

# Copy full module source including generated proto stubs
COPY rag-go/ ./

# Build a fully static binary — no libc dependency, safe for distroless
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
    go build -ldflags="-s -w" -o /rag-server ./main/

# ==========================================
# RUNTIME: Minimal distroless image (~2MB base)
# ==========================================
FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=builder /rag-server /rag-server

ENTRYPOINT ["/rag-server"]

