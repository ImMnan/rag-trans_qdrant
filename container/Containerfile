# ==========================================
# PRODUCTION BASE: Lean CPU Runtime
# ==========================================
FROM python:3.11-slim AS runtime

# Set execution flags for stability and unbuffered real-time logs
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    HF_HOME="/app/.cache/huggingface" \
    MODEL_DIR="/models/intfloat-multilingual-e5-large"

WORKDIR /app

# Install only minimal OS dependencies needed at runtime
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    && rm -rf /var/lib/apt/lists/*

# Copy and install pinned versions compatible with torch 2.4.1
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy your complete pure-cluster Python backend script
COPY rag_fastapi.py .

# Path reserved for external model mount (for example, GCS Fuse)
RUN mkdir -p /models /app/.cache/huggingface

# Expose internal FastAPI gateway port
EXPOSE 8000

# Execute the web API using Uvicorn worker threads
CMD ["uvicorn", "rag_fastapi:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "2"]
